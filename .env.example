# Example Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to GitHub!

# Navidrome Server Configuration
# Replace with your Navidrome server URL
# Examples:
#   - Local: http://localhost:4533
#   - Remote: http://192.168.1.100:4533
#   - Docker (same machine): http://host.docker.internal:4533 (Windows/Mac) or http://172.17.0.1:4533 (Linux)
#   - Domain: https://music.yourdomain.com
NAVIDROME_URL=http://localhost:4533

# Your Navidrome Username
NAVIDROME_USERNAME=your_username_here

# Your Navidrome Password
NAVIDROME_PASSWORD=your_password_here

# Server Configuration
# Port for the overlay server (default: 3000)
PORT=3000

# How often to poll Navidrome for updates (in milliseconds)
# Default: 2000 (2 seconds)
# Lower = more responsive, but more API calls
# Higher = less API calls, but slower updates
UPDATE_INTERVAL=2000
